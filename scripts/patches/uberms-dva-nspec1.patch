From 754f7e978e73addf590f8897685ca333b933895d Mon Sep 17 00:00:00 2001
From: Ryan Foley <foley@ucsc.edu>
Date: Wed, 15 Jul 2026 18:25:52 -0700
Subject: [PATCH] [AI Checkpoint] Allow dva sviMS/sviTP with nspec=1

Dark Hunter SED needs single-epoch UMS; models already support n=1.
Also honor omit_parallax_likelihood in dva run().

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 uberMS/dva/runSVI.py | 25 +++++++++++--------------
 1 file changed, 11 insertions(+), 14 deletions(-)

diff --git a/uberMS/dva/runSVI.py b/uberMS/dva/runSVI.py
index 1d4de91..299f295 100644
--- a/uberMS/dva/runSVI.py
+++ b/uberMS/dva/runSVI.py
@@ -41,10 +41,9 @@ class sviMS(object):
 
         self.rng_key = jrandom.PRNGKey(0)
 
-        if isinstance(self.specNN,str):
-            print('User input only one spectrum, please use standard uberMS (not dva)')
-            print(self.specNN)
-            raise IOError
+        if isinstance(self.specNN, str):
+            # Single path → one-element list (dva models support nspec=1).
+            self.specNN = [self.specNN]
 
         # determine how many spec user inputed
         if self.specNN is not None:
@@ -53,11 +52,11 @@ class sviMS(object):
             self.nspec = 0            
 
         if self.nspec == 1:
-            print('User input only one spectrum, please use standard uberMS (not dva)')
-            raise IOError
+            print('Note: dva sviMS with nspec=1 (same model path as multi-epoch).')
 
         self.genspecfn = []
         self.vmic_bool = []        
+        
         for ii in range(self.nspec):
             # initialize prediction classes
             GM = GenMod()
@@ -201,7 +200,7 @@ class sviMS(object):
             })
 
         # cycle through possible additional parameters
-        if 'parallax' in data.keys():
+        if not indict.get('omit_parallax_likelihood') and 'parallax' in data.keys():
             modelkw['additionalinfo']['parallax'] = data['parallax']
         # pass info about if vmic is included in NN labels
         if any(self.vmic_bool):
@@ -306,9 +305,8 @@ class sviTP(object):
 
         self.rng_key = jrandom.PRNGKey(0)
 
-        if isinstance(self.specNN,str):
-            print('User input only one spectrum, please use standard uberMS (not dva)')
-            return IOError
+        if isinstance(self.specNN, str):
+            self.specNN = [self.specNN]
 
         # determine how many spec user inputed
         if self.specNN is not None:
@@ -317,8 +315,7 @@ class sviTP(object):
             self.nspec = 0            
 
         if self.nspec == 1:
-            print('User input only one spectrum, please use standard uberMS (not dva)')
-            return IOError
+            print('Note: dva sviTP with nspec=1 (same model path as multi-epoch).')
         
         self.genspecfn = []
         self.vmic_bool = []        
@@ -441,7 +438,7 @@ class sviTP(object):
             })
         
         # cycle through possible additional parameters
-        if 'parallax' in data.keys():
+        if not indict.get('omit_parallax_likelihood') and 'parallax' in data.keys():
             modelkw['additionalinfo']['parallax'] = data['parallax']
         # pass info about if vmic is included in NN labels
         if any(self.vmic_bool):
@@ -501,4 +498,4 @@ class sviTP(object):
         sys.stdout.flush()
 
         return (svi,guide,svi_result)
-        
\ No newline at end of file
+        
-- 
